{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Kaivue on-prem or cloud Prometheus",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "KAI-422 — Customer Admin: system health, storage, camera counts. No brand assets.",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "stat",
      "id": 1,
      "title": "Build Version",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "name", "colorMode": "none" },
      "targets": [
        {
          "expr": "kaivue_build_info",
          "legendFormat": "{{version}} ({{commit}})",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Goroutines",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "none" },
      "targets": [
        { "expr": "kaivue_goroutines", "legendFormat": "goroutines", "refId": "A" }
      ]
    },
    {
      "type": "gauge",
      "id": 3,
      "title": "Heap Alloc (bytes)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "decbytes" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "kaivue_memory_bytes{type=\"heap_alloc\"}", "legendFormat": "heap_alloc", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "id": 4,
      "title": "Request Rate (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (component) (rate(kaivue_requests_total[5m]))",
          "legendFormat": "{{component}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 5,
      "title": "Request Latency P95 (s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (component, le) (rate(kaivue_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{component}} p95",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 6,
      "title": "Error Rate by Component",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (component, code) (rate(kaivue_errors_total[5m]))",
          "legendFormat": "{{component}} / {{code}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 7,
      "title": "Active Recorder Connections",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(kaivue_recordercontrol_connected)",
          "legendFormat": "connected recorders",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 8,
      "title": "Cert Expiry (Unix timestamp)",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "expr": "kaivue_certmgr_cert_expires_at", "legendFormat": "cert expires at", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "id": 9,
      "title": "Cert Renewals",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "expr": "rate(kaivue_certmgr_renewals_total[10m])",
          "legendFormat": "renewals {{result}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["kaivue", "customer-admin"],
  "templating": { "list": [] },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Kaivue — Customer Admin",
  "uid": "kaivue-customer-admin",
  "version": 1
}
