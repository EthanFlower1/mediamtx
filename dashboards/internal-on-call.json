{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Kaivue cloud or on-prem Prometheus",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "KAI-422 — Internal on-call: full component health, SLI/SLO indicators, cert expiry, reconnect storms.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "stat",
      "id": 1,
      "title": "Build Info",
      "gridPos": { "h": 3, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "name", "colorMode": "none" },
      "targets": [
        { "expr": "kaivue_build_info", "legendFormat": "{{version}} @{{commit}} ({{goversion}})", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Goroutines",
      "gridPos": { "h": 3, "w": 3, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        { "expr": "kaivue_goroutines", "legendFormat": "goroutines", "refId": "A" }
      ]
    },
    {
      "type": "gauge",
      "id": 3,
      "title": "Heap In-Use (bytes)",
      "gridPos": { "h": 3, "w": 5, "x": 9, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "decbytes", "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null },
        { "color": "yellow", "value": 500000000 },
        { "color": "red", "value": 1000000000 }
      ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "kaivue_memory_bytes{type=\"heap_inuse\"}", "legendFormat": "heap_inuse", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "id": 4,
      "title": "Request Rate by Component",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 3 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (component) (rate(kaivue_requests_total[2m]))",
          "legendFormat": "{{component}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 5,
      "title": "Error Rate by Component + Code",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 3 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (component, code) (rate(kaivue_errors_total[2m]))",
          "legendFormat": "{{component}} / {{code}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 6,
      "title": "P50 / P95 / P99 Latency (all components)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 11 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (component, le) (rate(kaivue_request_duration_seconds_bucket[2m])))",
          "legendFormat": "{{component}} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (component, le) (rate(kaivue_request_duration_seconds_bucket[2m])))",
          "legendFormat": "{{component}} p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (component, le) (rate(kaivue_request_duration_seconds_bucket[2m])))",
          "legendFormat": "{{component}} p99",
          "refId": "C"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 7,
      "title": "Recorder Control: Connected / Reconnects",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "expr": "sum(kaivue_recordercontrol_connected)", "legendFormat": "connected", "refId": "A" },
        {
          "expr": "sum by (reason) (rate(kaivue_recordercontrol_reconnects_total[5m]))",
          "legendFormat": "reconnect / {{reason}}",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 8,
      "title": "Directory Ingest: Messages + Backpressure Drops",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (stream, result) (rate(kaivue_directoryingest_messages_total[2m]))",
          "legendFormat": "{{stream}} / {{result}}",
          "refId": "A"
        },
        {
          "expr": "rate(kaivue_directoryingest_backpressure_drops_total[2m])",
          "legendFormat": "backpressure drops",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 9,
      "title": "CertMgr: Cert Expiry + Renewal Rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "dateTimeFromNow" }, "overrides": [] },
      "targets": [
        { "expr": "kaivue_certmgr_cert_expires_at * 1000", "legendFormat": "cert expires at", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "id": 10,
      "title": "CertMgr: Renewals + Re-Enrollments",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 27 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "expr": "rate(kaivue_certmgr_renewals_total[10m])",
          "legendFormat": "renewal / {{result}}",
          "refId": "A"
        },
        {
          "expr": "rate(kaivue_certmgr_reenrollments_total[10m])",
          "legendFormat": "re-enroll / {{result}}",
          "refId": "B"
        }
      ]
    },
    {
      "type": "table",
      "id": 11,
      "title": "5xx Error Rate by Route (top 10)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "footer": { "show": false }, "sortBy": [{ "displayName": "Value", "desc": true }] },
      "targets": [
        {
          "expr": "topk(10, sum by (component, route, code) (rate(kaivue_requests_total{code=~\"5..\"}[5m])))",
          "legendFormat": "{{component}} {{route}} {{code}}",
          "refId": "A",
          "instant": true
        }
      ]
    }
  ],
  "refresh": "15s",
  "schemaVersion": 38,
  "tags": ["kaivue", "internal", "on-call"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Kaivue — Internal On-Call",
  "uid": "kaivue-internal-on-call",
  "version": 1
}
